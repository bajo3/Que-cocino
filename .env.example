NODE_ENV=development

# --- Postgres / Supabase ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=whatsapp-media

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Z.AI / GLM model routing ---
ZAI_API_KEY=
# Routine analysis, summaries and task extraction.
ZAI_FAST_MODEL=glm-4.7-flash
# Fallback for ambiguous or complex requests.
ZAI_MODEL=glm-5.2
ZAI_TRANSCRIPTION_MODEL=glm-asr-2512
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# --- Redis (BullMQ) ---
REDIS_URL=

# --- WhatsApp / Baileys ---
WA_AUTH_DIR=./.wa_auth
# JID of the chat used to send control commands (e.g. 549XXXXXXXXXX@s.whatsapp.net)
CONTROL_CHAT_JID=
# Your own phone in international format without + (e.g. 549XXXXXXXXXX)
OWNER_PHONE=

# --- App / Dashboard ---
APP_SECRET=change-me-to-a-long-random-string
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me

# --- Feature flags / safety switches ---
# If true, ask for confirmation in the control chat before sending
CONFIRM_BEFORE_SEND=false
# Responsible outbound pacing. Set SEND_MAX_PER_HOUR=0 to block all outbound sends.
SEND_MAX_PER_HOUR=20
SEND_MAX_PER_CHAT_PER_HOUR=4
SEND_CHAT_COOLDOWN_MS=45000
SEND_DUPLICATE_WINDOW_MS=86400000
SEND_MIN_DISPATCH_DELAY_MS=1500
SEND_DELAY_PER_CHAR_MS=15
SEND_MAX_DISPATCH_DELAY_MS=12000
ENABLE_AUDIO_TRANSCRIPTION=true
# Master switch for outbound sending. If false, the system NEVER sends.
ENABLE_AUTO_SEND=true
# Download images/videos. Off by default (only audio is downloaded).
ENABLE_MEDIA_DOWNLOAD=false
ENABLE_AUDIO_DOWNLOAD=true

# --- Ports ---
LISTENER_HEALTH_PORT=3001
WORKER_HEALTH_PORT=3002
