# Obligatoria. URL de una base PostgreSQL dedicada a esta aplicación.
DATABASE_URL=""

# Obligatoria. No la completes a mano: ejecutá `npm run auth:secret`.
AUTH_SECRET=""
AUTH_URL="http://localhost:3004"

# Opcional. Sin IA, la carga rápida usa el parser determinista local.
ZAI_API_KEY=""
ZAI_BASE_URL="https://api.z.ai/api/paas/v4/"
ZAI_FAST_MODEL="glm-4.7-flash"
ZAI_MODEL="glm-5"

# Proveedor alternativo opcional.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
