# PostgreSQL de Neon o Supabase. Para aislar la app en una base compartida:
# postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require&schema=que_cocino
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require&schema=que_cocino"

# Generar con: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3004"

# Opcional. Sin un proveedor de IA funciona el parser determinista para la carga rápida.
# Se prefiere Z.AI/GLM si está configurado (endpoint OpenAI-compatible).
ZAI_API_KEY=""
ZAI_BASE_URL="https://api.z.ai/api/paas/v4/"
ZAI_FAST_MODEL="glm-4.7-flash"
ZAI_MODEL="glm-5"

# Fallback opcional a OpenAI.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
