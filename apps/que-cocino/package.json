{
  "name": "que-cocino",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "node scripts/sync-production-catalog.mjs",
    "dev": "next dev -p 3004",
    "build": "next build",
    "start": "next start -p 3004",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:secret": "node scripts/generate-auth-secret.mjs",
    "prisma:local": "node --env-file=.env.local scripts/run-prisma-local.mjs",
    "db:generate": "npm run prisma:local -- generate",
    "db:migrate": "npm run prisma:local -- migrate dev",
    "db:deploy": "npm run prisma:local -- migrate deploy",
    "db:status": "npm run prisma:local -- migrate status",
    "db:seed": "npm run prisma:local -- db seed"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.0",
    "ai": "^6.0.83",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.66.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "4.0.10"
  }
}
