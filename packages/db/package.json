    "test": "vitest run --passWithNoTests",
    "migrate": "node dist/migrate.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@wma/shared": "workspace:*",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
